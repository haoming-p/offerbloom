# Copy this to backend/.env and fill in real values.
# docker-compose injects NEO4J_URI/USER/PASSWORD itself, so omit those here.

JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Frontend URL for CORS (matches docker-compose default)
FRONTEND_URL=http://localhost:5173

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 object storage
CLOUDFLARE_ACCOUNT_ID=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=offerbloom-files
R2_PUBLIC_URL=
